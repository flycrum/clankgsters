{
  "name": "clankgster",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for Clankgster agent tooling (Vite+).",
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "check": "vp check",
    "check-all": "pnpm check && pnpm -r run check",
    "clankgster-sync:clear": "CLANKGSTER_REPO_ROOT=\"$PWD\" pnpm -F @clankgster/sync run clankgster-sync:clear",
    "clankgster-sync:run": "CLANKGSTER_REPO_ROOT=\"$PWD\" pnpm -F @clankgster/sync run clankgster-sync:run",
    "e2e-tests:clear": "pnpm -F @clankgster/sync-e2e run e2e-tests:clear",
    "e2e-tests:run": "pnpm -F @clankgster/sync-e2e run e2e-tests:run",
    "fix": "pnpm exec vp fmt && pnpm exec vp lint --fix",
    "fix-all": "pnpm fix && pnpm -r --if-present run fix",
    "test": "vp run @clankgster/sync#build && vp run -r test && vp run -w test-root",
    "test-and-check-all": "pnpm check-all && pnpm test && pnpm e2e-tests:run",
    "test-and-fix-all": "pnpm fix-all && pnpm check-all && pnpm test && pnpm e2e-tests:run",
    "test-root": "vp test"
  },
  "devDependencies": {
    "@clankgster/vite-plus-config": "workspace:*",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
