{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# clankgsters-sync: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md", "packages/app/CLAUDE.md"]
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgsters-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            },
            {
              "name": "root-nested-regular",
              "source": "./.clank/plugins/root-nested-regular",
              "description": "root-nested-regular plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": [
            {
              "name": "root-nested-local",
              "source": "./.clank/plugins.local/root-nested-local",
              "description": "root-nested-local plugin",
              "version": "0.0.1"
            }
          ]
        },
        "shorthandRegular": {
          "plugins": [
            {
              "name": "root-shorthand-regular",
              "source": "./.clank-plugins/root-shorthand-regular",
              "description": "root-shorthand-regular plugin",
              "version": "0.0.1"
            }
          ]
        },
        "shorthandLocal": {
          "plugins": [
            {
              "name": "root-shorthand-local",
              "source": "./.clank-plugins.local/root-shorthand-local",
              "description": "root-shorthand-local plugin",
              "version": "0.0.1"
            }
          ]
        }
      }
    },
    "AgentRulesSymlinkSyncPreset": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgsters-claude-sync.json"
      },
      "symlinks": [".claude/rules/root/root-rule.md"]
    },
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [
        ".claude/skills/sample-skill",
        ".claude/skills/skill-nested-local",
        ".claude/skills/skill-nested-regular",
        ".claude/skills/skill-shorthand-local",
        ".claude/skills/skill-shorthand-regular"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [".claude/skills/sample-skill", ".claude/skills/skill-nested-regular"]
        },
        "nestedLocal": {
          "symlinks": [".claude/skills/skill-nested-local"]
        },
        "shorthandRegular": {
          "symlinks": [".claude/skills/skill-shorthand-regular"]
        },
        "shorthandLocal": {
          "symlinks": [".claude/skills/skill-shorthand-local"]
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgsters-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  }
}
