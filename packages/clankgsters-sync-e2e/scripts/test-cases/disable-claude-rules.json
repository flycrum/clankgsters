{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md"
      },
      "symlinks": [
        "CLAUDE.md",
        "packages/app/CLAUDE.md"
      ]
    },
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".claude/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [
        ".claude/skills/sample-skill"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".claude/skills/sample-skill"
          ]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude/marketplace.json",
        "marketplaceName": "clankgsters-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgsters-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".testagent/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [
        ".testagent/skills/sample-skill"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".testagent/skills/sample-skill"
          ]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "CLANK.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  }
}
