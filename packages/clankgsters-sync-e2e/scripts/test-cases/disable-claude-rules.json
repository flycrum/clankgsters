{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# __CLANKGSTERS_LOCAL_MARKETPLACE_NAME__: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md", "packages/app/CLAUDE.md"]
    },
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"],
      "customData": {
        "nestedRegular": {
          "symlinks": [".claude/skills/sample-skill"]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "Fake nested plugin under packages/app for e2e test sandbox.",
              "version": "0.1.0"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "Fake root plugin for e2e test sandbox.",
              "version": "0.1.0"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": []
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  }
}
