{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# __CLANKGSTERS_LOCAL_MARKETPLACE_NAME__: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md", "packages/app/CLAUDE.md"]
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "Fake nested plugin under packages/app for e2e test sandbox.",
              "version": "0.1.0"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentRulesSymlinkSyncPreset": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgsters-claude-sync.json"
      },
      "symlinks": []
    },
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"],
      "customData": {
        "nestedRegular": {
          "symlinks": [".claude/skills/sample-skill"]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "__CLANKGSTERS_LOCAL_MARKETPLACE_NAME__",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": []
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "PluginsDirectorySyncPreset": {
      "options": {
        "customHandler": {},
        "requiredManifestKey": "cursor",
        "targetRoot": ".cursor"
      },
      "symlinks": [".cursor/commands/nested/nested-cmd.md"],
      "fsAutoRemoval": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [".cursor/commands/nested/nested-cmd.md"],
          "fsAutoRemoval": []
        },
        "nestedLocal": {
          "symlinks": [],
          "fsAutoRemoval": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "fsAutoRemoval": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "fsAutoRemoval": []
        }
      }
    }
  },
  "codex": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "AGENTS.md",
        "gitignoreComment": "\n# __CLANKGSTERS_LOCAL_MARKETPLACE_NAME__: symlinked from CLANK.md for Codex\n",
        "gitignoreEntry": "AGENTS.md"
      },
      "symlinks": ["AGENTS.md", "packages/app/AGENTS.md"]
    },
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": []
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": []
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "agentsFile": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  }
}
