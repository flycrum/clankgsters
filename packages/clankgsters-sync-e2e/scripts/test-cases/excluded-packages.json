{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# clankgsters-sync: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": [
        "CLAUDE.md"
      ]
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgsters-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentRulesSymlinkSyncPreset": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgsters-claude-sync.json"
      },
      "symlinks": [
        ".claude/rules/root/root-rule.md"
      ]
    },
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".claude/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [
        ".claude/skills/sample-skill"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".claude/skills/sample-skill"
          ]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgsters-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".cursor/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [
        ".cursor/skills/sample-skill"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".cursor/skills/sample-skill"
          ]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "PluginsDirectorySyncPreset": {
      "options": {
        "targetRoot": ".cursor",
        "rulesMarkdownFrontmatter": "---\nalwaysApply: true\n---\n\n"
      },
      "symlinks": [
        ".cursor/commands/root/root-cmd.md"
      ],
      "fsAutoRemoval": [
        ".cursor/rules/root/root-rule.mdc"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".cursor/commands/root/root-cmd.md"
          ],
          "fsAutoRemoval": [
            ".cursor/rules/root/root-rule.mdc"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "fsAutoRemoval": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "fsAutoRemoval": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "fsAutoRemoval": []
        }
      }
    }
  },
  "codex": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "AGENTS.md",
        "gitignoreComment": "\n# clankgsters-sync: symlinked from CLANK.md for Codex\n",
        "gitignoreEntry": "AGENTS.md"
      },
      "symlinks": [
        "AGENTS.md"
      ]
    },
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".agents/skills",
        "skillsDirectorySyncEnabled": false
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": []
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "options": {
        "nativeSkillsDir": ".testagent/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [
        ".testagent/skills/sample-skill"
      ],
      "customData": {
        "nestedRegular": {
          "symlinks": [
            ".testagent/skills/sample-skill"
          ]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "CLANK.md",
        "sectionHeading": "packages (generated by clankgsters)"
      }
    }
  }
}
