{
  "claude": {
    "MarkdownSymlinkSyncPreset": {
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md",
        "gitignoreComment": "\n# clankgsters-sync: symlinked from AGENTS.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md"
      },
      "symlinks": ["CLAUDE.md", "packages/app/CLAUDE.md"]
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgsters-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "root",
              "source": "./.clank/plugins-custom/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentRulesSymlinkSyncPreset": {
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgsters-claude-sync.json"
      },
      "symlinks": [".claude/rules/root/root-rule.md"]
    },
    "SkillsDirectorySyncPreset": {
      "options": {},
      "symlinks": [".claude/skills/sample-skill"],
      "customData": {
        "nestedRegular": {
          "symlinks": [".claude/skills/sample-skill"]
        },
        "nestedLocal": {
          "symlinks": []
        },
        "shorthandRegular": {
          "symlinks": []
        },
        "shorthandLocal": {
          "symlinks": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgsters-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  }
}
