{
  "name": "@clankgsters/sync",
  "version": "0.0.1",
  "description": "Node tooling and TypeScript scripts for Clankgsters sync workflows (publishable).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flycrum/clankgsters.git",
    "directory": "packages/clankgsters-sync"
  },
  "bin": {
    "clankgsters-sync": "./bin/clankgsters-sync.mjs"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts",
    "check": "vp check",
    "clankgsters-sync:clear": "tsx scripts/clankgsters-sync.clear.ts",
    "clankgsters-sync:run": "tsx scripts/clankgsters-sync.run.ts",
    "dev": "vp pack src/index.ts --watch",
    "prepublishOnly": "vp pack src/index.ts",
    "test": "vp test"
  },
  "dependencies": {
    "@types/lodash-es": "catalog:",
    "chalk": "catalog:",
    "lodash-es": "catalog:",
    "neverthrow": "catalog:",
    "pino": "catalog:",
    "tsx": "^4.19.0",
    "xstate": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@clankgsters/typescript-config": "workspace:*",
    "@clankgsters/vite-plus-config": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
