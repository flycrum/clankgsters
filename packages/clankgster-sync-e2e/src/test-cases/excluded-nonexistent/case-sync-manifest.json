{
  "claude": {
    "MarkdownContextSyncPreset": {
      "copies": ["CLAUDE.md", "packages/app/CLAUDE.md"],
      "options": {
        "gitignoreComment": "\n# clankgster-sync: symlinked from CLANK.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md",
        "targetFile": "CLAUDE.md",
        "sourceFile": "CLANK.md"
      },
      "symlinks": []
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgster-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentRulesDirectorySyncPreset": {
      "copies": [".claude/rules/root/root-rule.md"],
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgster-claude-sync.json"
      },
      "symlinks": []
    },
    "SkillsDirectorySyncPreset": {
      "copies": [
        ".claude/skills/nested-nested-fake-skill/SKILL.md",
        ".claude/skills/root-root-fake-skill/SKILL.md",
        ".claude/skills/sample-skill/SKILL.md"
      ],
      "options": {
        "nativeSkillsDir": ".claude/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".claude/skills/nested-nested-fake-skill/SKILL.md",
            ".claude/skills/root-root-fake-skill/SKILL.md",
            ".claude/skills/sample-skill/SKILL.md"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgster-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "cursor": {
    "SkillsDirectorySyncPreset": {
      "copies": [
        ".cursor/skills/nested-nested-fake-skill/SKILL.md",
        ".cursor/skills/root-root-fake-skill/SKILL.md",
        ".cursor/skills/sample-skill/SKILL.md"
      ],
      "options": {
        "nativeSkillsDir": ".cursor/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".cursor/skills/nested-nested-fake-skill/SKILL.md",
            ".cursor/skills/root-root-fake-skill/SKILL.md",
            ".cursor/skills/sample-skill/SKILL.md"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "PluginsDirectorySyncPreset": {
      "copies": [
        ".cursor/commands/root/root-cmd.md",
        ".cursor/rules/root/root-rule.mdc",
        ".cursor/commands/nested/nested-cmd.md"
      ],
      "options": {
        "targetRoot": ".cursor",
        "rulesMarkdownFrontmatter": "---\nalwaysApply: true\n---\n\n"
      },
      "symlinks": [],
      "fsAutoRemoval": [".cursor/rules/root/root-rule.mdc"],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".cursor/commands/root/root-cmd.md",
            ".cursor/rules/root/root-rule.mdc",
            ".cursor/commands/nested/nested-cmd.md"
          ],
          "fsAutoRemoval": [".cursor/rules/root/root-rule.mdc"]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": [],
          "fsAutoRemoval": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": [],
          "fsAutoRemoval": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": [],
          "fsAutoRemoval": []
        }
      }
    }
  },
  "codex": {
    "MarkdownContextSyncPreset": {
      "copies": ["AGENTS.md", "packages/app/AGENTS.md"],
      "options": {
        "gitignoreComment": "\n# clankgster-sync: symlinked from CLANK.md for Codex\n",
        "gitignoreEntry": "AGENTS.md",
        "targetFile": "AGENTS.md",
        "sourceFile": "CLANK.md"
      },
      "symlinks": []
    },
    "SkillsDirectorySyncPreset": {
      "copies": [],
      "options": {
        "nativeSkillsDir": ".agents/skills",
        "skillsDirectorySyncEnabled": false
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": []
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "AGENTS.override.md",
        "sectionHeading": "packages (generated by clankgster)"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "copies": [".testagent/skills/sample-skill/SKILL.md"],
      "options": {
        "nativeSkillsDir": ".testagent/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [".testagent/skills/sample-skill/SKILL.md"]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "CLANK.md",
        "sectionHeading": "packages (generated by clankgster)"
      }
    }
  }
}
