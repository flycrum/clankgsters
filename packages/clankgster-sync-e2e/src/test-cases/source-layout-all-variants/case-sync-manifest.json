{
  "claude": {
    "MarkdownContextSyncPreset": {
      "copies": [
        "CLAUDE.md",
        "packages/app/CLAUDE.md"
      ],
      "options": {
        "gitignoreComment": "\n# clankgster-sync: symlinked from CLANK.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md",
        "targetFile": "CLAUDE.md",
        "sourceFile": "CLANK.md"
      },
      "symlinks": []
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgster-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            },
            {
              "name": "root-nested-regular",
              "source": "./.clank/plugins/root-nested-regular",
              "description": "root-nested-regular plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": [
            {
              "name": "root-nested-local",
              "source": "./.clank/plugins.local/root-nested-local",
              "description": "root-nested-local plugin",
              "version": "0.0.1"
            }
          ]
        },
        "shorthandRegular": {
          "plugins": [
            {
              "name": "root-shorthand-regular",
              "source": "./.clank-plugins/root-shorthand-regular",
              "description": "root-shorthand-regular plugin",
              "version": "0.0.1"
            }
          ]
        },
        "shorthandLocal": {
          "plugins": [
            {
              "name": "root-shorthand-local",
              "source": "./.clank-plugins.local/root-shorthand-local",
              "description": "root-shorthand-local plugin",
              "version": "0.0.1"
            }
          ]
        }
      }
    },
    "AgentRulesDirectorySyncPreset": {
      "copies": [
        ".claude/rules/root/root-rule.md"
      ],
      "options": {
        "rulesDir": ".claude/rules",
        "syncManifest": ".claude/.clankgster-claude-sync.json"
      },
      "symlinks": []
    },
    "SkillsDirectorySyncPreset": {
      "copies": [
        ".claude/skills/nested-nested-fake-skill/SKILL.md",
        ".claude/skills/root-root-fake-skill/SKILL.md",
        ".claude/skills/sample-skill/SKILL.md",
        ".claude/skills/skill-nested-local/SKILL.md",
        ".claude/skills/skill-nested-regular/SKILL.md",
        ".claude/skills/skill-shorthand-local/SKILL.md",
        ".claude/skills/skill-shorthand-regular/SKILL.md"
      ],
      "options": {
        "nativeSkillsDir": ".claude/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".claude/skills/nested-nested-fake-skill/SKILL.md",
            ".claude/skills/root-root-fake-skill/SKILL.md",
            ".claude/skills/sample-skill/SKILL.md",
            ".claude/skills/skill-nested-regular/SKILL.md"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": [
            ".claude/skills/skill-nested-local/SKILL.md"
          ]
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": [
            ".claude/skills/skill-shorthand-regular/SKILL.md"
          ]
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": [
            ".claude/skills/skill-shorthand-local/SKILL.md"
          ]
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgster-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  }
}
