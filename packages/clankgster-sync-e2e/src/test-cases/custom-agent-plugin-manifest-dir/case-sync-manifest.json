{
  "testagent": {
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "testagent",
        "marketplaceFile": ".testagent/marketplace.json",
        "marketplaceName": "clankgster-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "SkillsDirectorySyncPreset": {
      "copies": [
        ".testagent/skills/root-root-fake-skill/SKILL.md",
        ".testagent/skills/sample-skill/SKILL.md"
      ],
      "options": {
        "nativeSkillsDir": ".testagent/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".testagent/skills/root-root-fake-skill/SKILL.md",
            ".testagent/skills/sample-skill/SKILL.md"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    }
  }
}
