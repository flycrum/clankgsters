{
  "claude": {
    "MarkdownContextSyncPreset": {
      "copies": [],
      "options": {
        "gitignoreComment": "\n# clankgster-sync: symlinked from CLANK.md for Claude\n",
        "gitignoreEntry": "CLAUDE.md",
        "targetFile": "CLAUDE.md",
        "sourceFile": "CLANK.md"
      },
      "symlinks": []
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude-plugin/marketplace.json",
        "marketplaceName": "clankgster-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgster-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  }
}
