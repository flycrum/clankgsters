{
  "claude": {
    "MarkdownContextSyncPreset": {
      "copies": ["CLAUDE.md", "packages/app/CLAUDE.md"],
      "options": {
        "sourceFile": "CLANK.md",
        "targetFile": "CLAUDE.md"
      },
      "symlinks": []
    },
    "SkillsDirectorySyncPreset": {
      "copies": [
        ".claude/skills/nested-nested-fake-skill/SKILL.md",
        ".claude/skills/root-root-fake-skill/SKILL.md",
        ".claude/skills/sample-skill/SKILL.md"
      ],
      "options": {
        "nativeSkillsDir": ".claude/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [
            ".claude/skills/nested-nested-fake-skill/SKILL.md",
            ".claude/skills/root-root-fake-skill/SKILL.md",
            ".claude/skills/sample-skill/SKILL.md"
          ]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "AgentMarketplaceJsonSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceFile": ".claude/marketplace.json",
        "marketplaceName": "clankgster-sync",
        "sourceFormat": "prefixed"
      },
      "customData": {
        "nestedRegular": {
          "plugins": [
            {
              "name": "nested",
              "source": "./packages/app/.clank/plugins/nested",
              "description": "nested plugin",
              "version": "0.0.1"
            },
            {
              "name": "root",
              "source": "./.clank/plugins/root",
              "description": "root plugin",
              "version": "0.0.1"
            }
          ]
        },
        "nestedLocal": {
          "plugins": []
        },
        "shorthandRegular": {
          "plugins": []
        },
        "shorthandLocal": {
          "plugins": []
        }
      }
    },
    "AgentSettingsSyncPreset": {
      "options": {
        "manifestKey": "claude",
        "marketplaceName": "clankgster-sync",
        "settingsFile": ".claude/settings.json"
      }
    }
  },
  "testagent": {
    "SkillsDirectorySyncPreset": {
      "copies": [".testagent/skills/sample-skill/SKILL.md"],
      "options": {
        "nativeSkillsDir": ".testagent/skills",
        "skillsDirectorySyncEnabled": true
      },
      "symlinks": [],
      "customData": {
        "nestedRegular": {
          "symlinks": [],
          "copies": [".testagent/skills/sample-skill/SKILL.md"]
        },
        "nestedLocal": {
          "symlinks": [],
          "copies": []
        },
        "shorthandRegular": {
          "symlinks": [],
          "copies": []
        },
        "shorthandLocal": {
          "symlinks": [],
          "copies": []
        }
      }
    },
    "MarkdownSectionSyncPreset": {
      "options": {
        "markdownContextOverrideFileName": "CLANK.md",
        "sectionHeading": "packages (generated by clankgster)"
      }
    }
  }
}
