{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "types": ["node"],
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  }
}
