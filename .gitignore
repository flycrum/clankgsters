# Clankgster sync output (regenerated locally; not source of truth)
.clankgster-cache/
.clank/.cache/
.clank/.logs/
.superagent/

# Library-specific files
clankgster.config.local.ts

# Ignore root-level Claude and Cursor plugin dirs (sync scripts; do not commit)
# Note: plugin dirs under .clank/ (e.g. .clank/plugins/*/.claude-plugin/) remain tracked (as required by plugin marketplace sync)
/.claude-plugin/
/.cursor-plugin/
# Recursively ignore these (not required by the system definitions)
.claude/
.cursor/

# Clankgster: potentially generated agent context files (any depth)
**/AGENTS.md
# Clankgster: Codex marketplace section (potentially generated by clankgster sync)
AGENTS.override.md
# Clankgster: symlinked from CLANK.md for Claude (when Claude marketplace sync is enabled)
CLAUDE.md

# Dependencies
node_modules/

# Build outputs
dist/

# Scratch / ephemeral dirs (tests, local tooling); conventional name used across ecosystems
tmp/

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.DS_Store
*.log

