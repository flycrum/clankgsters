packages/clankgsters-sync-integration-tests/sandboxes/.tests/

# Ignore root-level Claude and Cursor plugin dirs (sync scripts; do not commit)
# Note: plugin dirs under .agents/ (e.g. .agents/plugins/*/.claude-plugin/) remain tracked (as required by plugins/marketplace system)
/.claude-plugin/
/.cursor-plugin/
# Recursively ignore these (not required by the system definitions)
.claude/
.cursor/

# mmaappss: symlinked from AGENTS.md for Claude (when Claude marketplace sync is enabled)
CLAUDE.md
# mmaappss: Codex marketplace section (generated by mmaappss sync)
AGENTS.override.md

